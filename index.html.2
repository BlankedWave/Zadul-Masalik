                                    { text: '<b>Rukun Jual Beli:</b> Penjual, Pembeli, Barang, Harga, Ijab & Qabul. Syarat barang: Wujud, halal, bernilai, milik sah, boleh diserah.' },
                                    { text: '<b>Riba (Haram):</b> Tambahan hutang/tangguh (Nasiah) atau lebihan tukaran barang ribawi mcm emas/perak/makanan asasi yang sama jenis (Fadhl).' },
                                    { text: '<b>Hutang:</b> Wajib dibayar. Sunat catat kontrak hutang dan ambil saksi.' },
                                    { text: '<b>Khiyar (Hak Pengguna):</b> Hak memilih nak teruskan atau batal kontrak jika barang cacat (Khiyar Aib).' }
                                ]
                            },
                            {
                                title: 'Perniagaan Digital & Shopee',
                                points: [
                                    { text: '<b>Shopee/Lazada:</b> Sah asalkan akad jelas (klik butang \'Beli\' adalah ijab qabul moden). Barang dipaparkan spesifikasi jelas. Tiada unsur gharar (penipuan/ketidakpastian).' },
                                    { text: '<b>Dropship/Affiliate:</b> Halal jika patuh syariah, komisen jelas, barang halal, penjual agen sah.' },
                                    { text: '<b>Zakat & Sedekah Digital:</b> Sah bayar zakat pakai FPX/QR Pay kerana rohnya ialah perpindahan nilai wang dari pembayar ke asnaf/amil.' }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                title: 'K. Akhlak & Doa Harian',
                icon: 'smile',
                subtopics: [
                    {
                        label: 'Adab & Dosa Besar',
                        cards: [
                            {
                                title: 'Akhlak Muslim',
                                points: [
                                    { text: '<b>Makan/Minum:</b> Basmalah, tangan kanan, duduk, tidak mencela makanan.' },
                                    { text: '<b>Ibu Bapa & Jiran:</b> Haram sebut "Ah", wajib taat (selagi tak maksiat). Jiran: Dilarang menyakiti hati dengan bunyi bising/kenderaan halang jalan.' },
                                    { text: '<b>Menjaga Lidah:</b> Jauhi mengumpat (Ghibah), adu domba (Namimah), fitnah, dan dusta.' },
                                    { text: '<b>Dosa Besar:</b> Syirik, sihir, bunuh jiwa, makan harta anak yatim, riba, lari dari medan perang, tuduh wanita solehah berzina, derhaka ibu bapa.' }
                                ]
                            }
                        ]
                    },
                    {
                        label: 'Himpunan Doa Ringkas',
                        cards: [
                            {
                                title: 'Doa Utama Kehidupan',
                                points: [
                                    { label: 'Doa Makan', prayer: {
                                        ar: 'اللَّهُمَّ بَارِكْ لَنَا فِيمَا رَزَقْتَنَا وَقِنَا عَذَابَ النَّارِ',
                                        ru: 'Allahumma barik lana fima razaqtana waqina \'azaban nar',
                                        tr: 'Ya Allah, berkatilah rezeki yang telah Engkau kurniakan kepada kami, dan peliharalah kami dari azab neraka.'
                                    }},
                                    { label: 'Doa Sebelum Tidur', prayer: {
                                        ar: 'بِاسْمِكَ اللَّهُمَّ أَمُوتُ وَأَحْيَا',
                                        ru: 'Bismika Allahumma amutu wa ahya',
                                        tr: 'Dengan nama-Mu Ya Allah, aku mati dan aku hidup.'
                                    }},
                                    { label: 'Doa Ibu Bapa', prayer: {
                                        ar: 'رَبِّ اغْفِرْ لِي وَلِوَالِدَيَّ وَارْحَمْهُمَا كَمَا رَبَّيَانِي صَغِيرًا',
                                        ru: 'Rabbighfirli waliwalidayya warhamhuma kama rabbayani saghira',
                                        tr: 'Wahai Tuhanku, ampunilah aku dan kedua ibu bapaku, serta rahmatilah mereka berdua sepertimana mereka mendidikku sewaktu kecil.'
                                    }},
                                    { label: 'Kebaikan Dunia & Akhirat', prayer: {
                                        ar: 'رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ',
                                        ru: 'Rabbana atina fid-dunya hasanah, wafil akhirati hasanah, waqina \'azaban nar',
                                        tr: 'Ya Tuhan kami, berikanlah kami kebaikan di dunia dan kebaikan di akhirat, dan peliharalah kami dari seksa neraka.'
                                    }}
                                ]
                            }
                        ]
                    }
                ]
            }
        ];

        const totalPages = topics.length + 2;

        const next = () => { if (page.value < totalPages - 1) page.value++; };
        const prev = () => { if (page.value > 0) page.value--; };
        const goTo = (p) => { page.value = p; };

        watch(page, () => {
            setTimeout(() => lucide.createIcons(), 50);
            if (window.innerWidth <= 1024) window.scrollTo({ top: 0, behavior: 'smooth' });
        });

        onMounted(() => lucide.createIcons());

        return { page, topics, totalPages, next, prev, goTo };
    }
}).mount('#app');
</script>
</body>
</html>
